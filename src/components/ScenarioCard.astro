---
interface Props {
  title: string;
  description: string;
  capability: string;
  href: string;
  image?: string;
  badge?: string;
}

const { title, description, capability, href, image, badge } = Astro.props;
---

<a href={href} class="card-wrapper">
  <div class="card">
    {image && (
      <div class="card__image">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )}
    <div class="card__body">
      <div class="card__meta">
        <span class="badge badge--primary">{capability}</span>
        {badge && <span class="badge badge--accent">{badge}</span>}
      </div>
      <h3 class="card__title">{title}</h3>
      <p class="card__desc">{description}</p>
      <span class="card__link">
        Explore scenario
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
      </span>
    </div>
  </div>
</a>

<style>
  .card-wrapper {
    position: relative;
    border-radius: var(--card-frame-radius);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* Gradient ring — hidden by default */
  .card-wrapper::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: var(--card-frame-thickness);
    border-radius: inherit;
    background: var(--gradient-brand);
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    z-index: 1;
  }

  .card-wrapper:hover::before {
    opacity: 1;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--card-frame-radius);
    overflow: hidden;
    transition: all 0.25s ease;
    height: 100%;
  }
  .card-wrapper:hover .card {
    border-color: transparent;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--c-surface-raised);
    border-bottom: 1px solid var(--c-border-subtle);
  }
  .card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .card-wrapper:hover .card__image img {
    transform: scale(1.02);
  }
  .card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }
  .card__meta {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .card__title {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--c-text);
    margin-top: var(--space-xs);
  }
  .card__desc {
    font-size: 0.88rem;
    color: var(--c-text-secondary);
    line-height: 1.6;
    flex: 1;
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--c-primary);
    margin-top: var(--space-sm);
    transition: gap 0.2s ease;
  }
  .card-wrapper:hover .card__link {
    gap: 10px;
  }
</style>
